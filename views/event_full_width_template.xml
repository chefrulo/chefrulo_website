<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--
    When the event's Template (event_type_id) has use_full_width_layout = True:
    - Main content column becomes full-width (col-12)
    - Right sidebar (registration widget, date, location) is hidden
    - The registration modal (#modal_ticket_registration) stays in the DOM
      so Book buttons anywhere in the description work with:
        data-bs-toggle="modal" data-bs-target="#modal_ticket_registration"
-->
<template id="event_description_full_width" inherit_id="website_event.event_description_full">
    <xpath expr="//div[hasclass('col','pe-xxl-5')]" position="attributes">
        <attribute name="t-attf-class">#{event.event_type_id.use_full_width_layout and 'col-12' or 'col pe-xxl-5'}</attribute>
    </xpath>
    <xpath expr="//div[hasclass('d-lg-flex','justify-content-end','col-lg-4')]" position="attributes">
        <attribute name="t-if">not event.event_type_id.use_full_width_layout</attribute>
    </xpath>
</template>

</odoo>
