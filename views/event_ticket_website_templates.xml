<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!--
    Override the multi-ticket price block to show compare_price as strikethrough.
    Inherits from website_event_sale which already injected price into this div.
-->
<template id="event_ticket_compare_price" inherit_id="website_event_sale.modal_ticket_registration">
    <xpath expr="//div[hasclass('o_wevent_registration_multi_select')]" position="replace">
        <div class="o_wevent_registration_multi_select flex-md-grow-1 text-end">
            <t t-if="ticket.price">
                <!-- Compare (strikethrough) price from our custom field -->
                <t t-if="ticket.compare_price and ticket.compare_price > ticket.price">
                    <del class="text-muted me-1"
                         t-out="ticket.compare_price"
                         t-options="{'widget': 'monetary', 'from_currency': event.company_id.sudo().currency_id, 'display_currency': website.currency_id}"/>
                </t>
                <!-- Existing pricelist-based strikethrough (kept from core) -->
                <t t-elif="(ticket.price - ticket.price_reduce) &gt; 0 and website.pricelist_id.discount_policy == 'without_discount'">
                    <del t-if="website.show_line_subtotals_tax_selection == 'tax_excluded'"
                         class="text-danger me-1"
                         t-field="ticket.price"
                         t-options="{'widget': 'monetary', 'from_currency': event.company_id.sudo().currency_id, 'display_currency': website.currency_id}"/>
                    <del t-else=""
                         class="text-danger me-1"
                         t-field="ticket.price_incl"
                         t-options="{'widget': 'monetary', 'from_currency': event.company_id.sudo().currency_id, 'display_currency': website.currency_id}"/>
                </t>
                <span t-if="website.show_line_subtotals_tax_selection == 'tax_excluded'"
                      class="fs-6"
                      t-field="ticket.price_reduce"
                      t-options="{'widget': 'monetary', 'from_currency': event.company_id.sudo().currency_id, 'display_currency': website.currency_id}"/>
                <span t-else=""
                      class="fs-6"
                      t-field="ticket.price_reduce_taxinc"
                      t-options="{'widget': 'monetary', 'from_currency': event.company_id.sudo().currency_id, 'display_currency': website.currency_id}"/>
                <span itemprop="price" class="d-none" t-out="ticket.price"/>
                <span itemprop="priceCurrency" class="d-none" t-out="website.currency_id.name"/>
            </t>
            <span t-else="" class="badge text-bg-success rounded-pill p-2 px-3">Free</span>
        </div>
    </xpath>
</template>

</odoo>
