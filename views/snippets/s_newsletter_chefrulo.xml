<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Template content shown inside the Newsletter Block -->
<template id="s_newsletter_block_chefrulo_template" groups="base.group_user">
    <div class="s_newsletter_chefrulo py-5 text-center" style="background: linear-gradient(160deg, #111 0%, #2b1500 100%); border-radius: 8px;">
        <div class="row justify-content-center mx-0">
            <div class="col-lg-7 col-md-9 px-4 py-4">
                <p class="mb-3" style="color: #c8a060; font-size: 11px; letter-spacing: 4px; text-transform: uppercase; font-family: Georgia, serif;">
                    Chef Rulo · London
                </p>
                <h2 style="color: #fff; font-size: 34px; font-weight: normal; line-height: 1.3; font-family: Georgia, serif;">
                    The table was full.<br/>
                    <em style="color: #c8a060;">Don't miss the next one.</em>
                </h2>
                <p class="mt-3 mb-4" style="color: #bba882; font-size: 18px; line-height: 1.8; font-family: Georgia, serif;">
                    Every Argentine Experience is an afternoon in the garden —<br/>
                    different menu, good company, always sold out.<br/><br/>
                    Leave your email and we'll reach out
                    <strong style="color: #e8c888;">before anyone else</strong><br/>
                    when the next one is ready.
                </p>
                <section class="s_website_form" data-vcss="001" data-snippet="s_website_form" data-name="Form">
                    <form action="/website/form/" method="post" enctype="multipart/form-data"
                          class="o_mark_required"
                          data-mark="*"
                          data-model_name="mailing.contact"
                          data-success-mode="message"
                          hide-change-model="true">

                        <!-- Pre-select mailing list "Chef Rulo - Experiencia Argentina Next Event" -->
                        <div class="s_website_form_field d-none" data-type="many2many" data-name="Field">
                            <div class="s_website_form_multiple" data-name="list_ids">
                                <input type="checkbox" class="s_website_form_input" name="list_ids" value="3" checked="1"/>
                            </div>
                        </div>

                        <div class="row g-3 text-start">
                            <div class="col-12 s_website_form_field s_website_form_model_required" data-type="char" data-name="Field">
                                <input type="text" name="name" placeholder="Your name *"
                                       class="form-control s_website_form_input"
                                       style="background: rgba(255,255,255,0.1); border: 1px solid #5a4a36; color: #fff; padding: 14px 16px;"
                                       required="1"/>
                            </div>
                            <div class="col-12 s_website_form_field" data-type="char" data-name="Field">
                                <input type="tel" name="mobile" placeholder="Your phone"
                                       class="form-control s_website_form_input"
                                       style="background: rgba(255,255,255,0.1); border: 1px solid #5a4a36; color: #fff; padding: 14px 16px;"/>
                            </div>
                            <div class="col-12 s_website_form_field s_website_form_model_required" data-type="email" data-name="Field">
                                <input type="email" name="email" placeholder="your@email.com *"
                                       class="form-control s_website_form_input"
                                       style="background: rgba(255,255,255,0.1); border: 1px solid #5a4a36; color: #fff; padding: 14px 16px;"
                                       required="1"/>
                            </div>
                            <div class="col-12 s_website_form_submit" data-name="Submit Button">
                                <button type="submit" class="btn w-100 s_website_form_send"
                                        style="background: #c8a060; color: #111; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; padding: 14px; font-family: Georgia, serif;">
                                    Save my seat
                                </button>
                                <span id="s_website_form_result"></span>
                            </div>
                        </div>
                    </form>
                    <div class="s_website_form_end_message d-none">
                        <p class="mt-3" style="color: #c8a060; font-size: 16px; font-family: Georgia, serif;">
                            ✓ You're on the list. We'll be in touch — see you in the garden.
                        </p>
                    </div>
                </section>
                <p class="mt-3 mb-0" style="color: #5a4a36; font-size: 11px; font-family: Georgia, serif;">
                    No spam · One email when the next experience opens · Unsubscribe anytime
                </p>
            </div>
        </div>
    </div>
</template>

<!-- Add "Chef Rulo Experience" option to the Template dropdown -->
<template id="newsletter_subscribe_options_chefrulo" inherit_id="website_mass_mailing.newsletter_subscribe_options">
    <xpath expr="//we-select[@data-name='newsletter_template_opt']/we-button[last()]" position="after">
        <we-button title="Chef Rulo Experience"
                   string="Chef Rulo Experience"
                   data-select-template="chefrulo_website.s_newsletter_block_chefrulo_template"
                   data-select-data-attribute="chefrulo"
                   data-name="chefrulo_opt"/>
    </xpath>
</template>

</odoo>
