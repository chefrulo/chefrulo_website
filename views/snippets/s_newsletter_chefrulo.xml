<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Template content shown inside the Newsletter Block -->
<template id="s_newsletter_block_chefrulo_template" groups="base.group_user">
    <div class="s_newsletter_chefrulo py-5 text-center" style="background: linear-gradient(160deg, #111 0%, #2b1500 100%); border-radius: 8px;">
        <div class="row justify-content-center mx-0">
            <div class="col-lg-7 col-md-9 px-4 py-4">
                <p class="mb-3" style="color: #c8a060; font-size: 11px; letter-spacing: 4px; text-transform: uppercase; font-family: Georgia, serif;">
                    Chef Rulo · London
                </p>
                <h2 style="color: #fff; font-size: 34px; font-weight: normal; line-height: 1.3; font-family: Georgia, serif;">
                    The table was full.<br/>
                    <em style="color: #c8a060;">Don't miss the next one.</em>
                </h2>
                <p class="mt-3 mb-4" style="color: #bba882; font-size: 15px; line-height: 1.8; font-family: Georgia, serif;">
                    Every Argentine Experience is a one-night event —<br/>
                    different menu, same table, always sold out.<br/><br/>
                    Leave your email and we'll reach out
                    <strong style="color: #e8c888;">before anyone else</strong><br/>
                    when the next one is ready.
                </p>
                <t t-snippet-call="website_mass_mailing.s_newsletter_subscribe_form"/>
                <p class="mt-3 mb-0" style="color: #5a4a36; font-size: 11px; font-family: Georgia, serif;">
                    No spam · One email when the next experience opens · Unsubscribe anytime
                </p>
            </div>
        </div>
    </div>
</template>

<!-- Add "Chef Rulo Experience" option to the Template dropdown -->
<template id="newsletter_subscribe_options_chefrulo" inherit_id="website_mass_mailing.newsletter_subscribe_options">
    <xpath expr="//we-select[@data-name='newsletter_template_opt']/we-button[last()]" position="after">
        <we-button title="Chef Rulo Experience"
                   string="Chef Rulo Experience"
                   data-select-template="chefrulo_website.s_newsletter_block_chefrulo_template"
                   data-select-data-attribute="chefrulo"
                   data-name="chefrulo_opt"/>
    </xpath>
</template>

</odoo>
