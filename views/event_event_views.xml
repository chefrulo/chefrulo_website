<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- Add Full Width Layout checkbox to event.type (the "Template" selector) -->
<record id="view_event_type_full_width_layout" model="ir.ui.view">
    <field name="name">event.type.full_width_layout</field>
    <field name="model">event.type</field>
    <field name="inherit_id" ref="website_event.event_type_view_form"/>
    <field name="arch" type="xml">
        <span name="menu_register_cta" position="after">
            <span name="full_width_layout" class="d-inline-block">
                <label for="use_full_width_layout" string="Full Width Layout"/>
                <field name="use_full_width_layout"/>
            </span>
        </span>
    </field>
</record>

</odoo>
