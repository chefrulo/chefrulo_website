<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- RECIBO DE VENTA                                              -->
    <!-- ============================================================ -->
    <record id="action_report_sale_receipt" model="ir.actions.report">
        <field name="name">Recibo de Orden</field>
        <field name="model">sale.order</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">chefrulo_website.report_sale_receipt</field>
        <field name="report_file">chefrulo_website.report_sale_receipt</field>
        <field name="print_report_name">'Recibo - %s' % (object.name)</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_sale_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" style="padding: 30px; font-family: Arial, sans-serif;">

                    <!-- Encabezado -->
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; border-bottom: 2px solid #333; padding-bottom: 20px;">
                        <div>
                            <t t-if="o.env.company.logo">
                                <img t-att-src="image_data_uri(o.env.company.logo)" style="max-height: 70px; max-width: 200px;"/>
                            </t>
                            <div style="margin-top: 8px;">
                                <strong style="font-size: 14px;"><t t-esc="o.env.company.name"/></strong>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <h2 style="margin: 0; font-size: 24px; color: #333;">RECIBO</h2>
                            <div style="font-size: 18px; font-weight: bold; color: #555; margin-top: 5px;">
                                <t t-esc="o.name"/>
                            </div>
                            <div style="font-size: 12px; color: #777; margin-top: 5px;">
                                Fecha: <t t-esc="o.date_order.strftime('%d/%m/%Y %H:%M') if o.date_order else ''"/>
                            </div>
                        </div>
                    </div>

                    <!-- Datos del cliente -->
                    <div style="margin-bottom: 25px;">
                        <h4 style="margin: 0 0 8px 0; font-size: 13px; text-transform: uppercase; color: #555;">Cliente</h4>
                        <div style="font-size: 13px;">
                            <strong><t t-esc="o.partner_id.name"/></strong><br/>
                            <t t-if="o.partner_id.email">
                                <t t-esc="o.partner_id.email"/><br/>
                            </t>
                            <t t-if="o.partner_id.phone">
                                <t t-esc="o.partner_id.phone"/><br/>
                            </t>
                        </div>
                    </div>

                    <!-- Info de entrega -->
                    <t t-if="o.delivery_date or o.shipping_note">
                        <div style="background: #f8f8f8; border-left: 4px solid #333; padding: 10px 15px; margin-bottom: 25px; font-size: 13px;">
                            <t t-if="o.delivery_date">
                                <div><strong>Fecha de entrega:</strong> <t t-esc="o.delivery_date.strftime('%d/%m/%Y') if o.delivery_date else ''"/></div>
                            </t>
                            <t t-if="o.shipping_note">
                                <div style="margin-top: 4px;"><strong>Notas:</strong> <t t-esc="o.shipping_note"/></div>
                            </t>
                        </div>
                    </t>

                    <!-- Tabla de productos -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 20px;">
                        <thead>
                            <tr style="background: #333; color: white;">
                                <th style="padding: 8px 10px; text-align: left;">Producto</th>
                                <th style="padding: 8px 10px; text-align: center; width: 70px;">Cant.</th>
                                <th style="padding: 8px 10px; text-align: right; width: 100px;">Precio unit.</th>
                                <th style="padding: 8px 10px; text-align: right; width: 100px;">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.order_line" t-as="line">
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td style="padding: 8px 10px;">
                                        <t t-esc="line.product_id.name"/>
                                        <t t-if="line.name and line.name != line.product_id.name">
                                            <div style="font-size: 11px; color: #777; margin-top: 2px;"><t t-esc="line.name"/></div>
                                        </t>
                                    </td>
                                    <td style="padding: 8px 10px; text-align: center;">
                                        <t t-esc="'%g' % line.product_uom_qty"/>
                                        <span style="font-size: 11px; color: #999;"> <t t-esc="line.product_uom.name"/></span>
                                    </td>
                                    <td style="padding: 8px 10px; text-align: right;">
                                        <t t-esc="'£%.2f' % line.price_unit"/>
                                    </td>
                                    <td style="padding: 8px 10px; text-align: right;">
                                        <t t-esc="'£%.2f' % line.price_subtotal"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Totales -->
                    <div style="display: flex; justify-content: flex-end; margin-bottom: 30px;">
                        <table style="font-size: 13px; min-width: 250px;">
                            <tr>
                                <td style="padding: 4px 10px; color: #555;">Subtotal sin impuestos:</td>
                                <td style="padding: 4px 10px; text-align: right;">
                                    <t t-esc="'£%.2f' % o.amount_untaxed"/>
                                </td>
                            </tr>
                            <t t-if="o.amount_tax">
                                <tr>
                                    <td style="padding: 4px 10px; color: #555;">Impuestos:</td>
                                    <td style="padding: 4px 10px; text-align: right;">
                                        <t t-esc="'£%.2f' % o.amount_tax"/>
                                    </td>
                                </tr>
                            </t>
                            <tr style="border-top: 2px solid #333;">
                                <td style="padding: 8px 10px; font-weight: bold; font-size: 15px;">TOTAL:</td>
                                <td style="padding: 8px 10px; text-align: right; font-weight: bold; font-size: 15px;">
                                    <t t-esc="'£%.2f' % o.amount_total"/>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Pie -->
                    <div style="text-align: center; font-size: 11px; color: #999; border-top: 1px solid #eee; padding-top: 15px;">
                        <t t-esc="o.env.company.name"/> — Gracias por su pedido
                    </div>

                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- COMANDA DE COCINA                                            -->
    <!-- ============================================================ -->
    <record id="action_report_kitchen_comanda" model="ir.actions.report">
        <field name="name">Comanda de Cocina</field>
        <field name="model">sale.order</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">chefrulo_website.report_kitchen_comanda</field>
        <field name="report_file">chefrulo_website.report_kitchen_comanda</field>
        <field name="print_report_name">'Comanda - %s' % (object.name)</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_kitchen_comanda">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" style="padding: 25px; font-family: Arial, sans-serif; max-width: 400px; margin: 0 auto;">

                    <!-- Encabezado -->
                    <div style="text-align: center; border-bottom: 3px solid #000; padding-bottom: 15px; margin-bottom: 20px;">
                        <h1 style="margin: 0; font-size: 28px; letter-spacing: 2px; text-transform: uppercase;">COCINA</h1>
                        <div style="font-size: 36px; font-weight: bold; margin-top: 10px; letter-spacing: 1px;">
                            <t t-esc="o.name"/>
                        </div>
                        <div style="font-size: 13px; color: #555; margin-top: 8px;">
                            <t t-esc="o.date_order.strftime('%d/%m/%Y %H:%M') if o.date_order else ''"/>
                        </div>
                    </div>

                    <!-- Fecha de entrega -->
                    <t t-if="o.delivery_date">
                        <div style="text-align: center; background: #000; color: white; padding: 10px; margin-bottom: 20px; font-size: 16px; font-weight: bold;">
                            ENTREGA: <t t-esc="o.delivery_date.strftime('%d/%m/%Y') if o.delivery_date else ''"/>
                        </div>
                    </t>

                    <!-- Notas especiales -->
                    <t t-if="o.shipping_note">
                        <div style="border: 2px dashed #000; padding: 10px; margin-bottom: 20px; font-size: 13px;">
                            <strong>NOTAS:</strong><br/>
                            <t t-esc="o.shipping_note"/>
                        </div>
                    </t>

                    <!-- Productos -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
                        <thead>
                            <tr style="border-bottom: 2px solid #000;">
                                <th style="padding: 6px 5px; text-align: left; font-size: 12px; text-transform: uppercase; color: #555;">Producto</th>
                                <th style="padding: 6px 5px; text-align: right; font-size: 12px; text-transform: uppercase; color: #555; width: 60px;">Cant.</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.order_line" t-as="line">
                                <tr style="border-bottom: 1px solid #ccc;">
                                    <td style="padding: 10px 5px; font-size: 16px; font-weight: bold;">
                                        <t t-esc="line.product_id.name"/>
                                    </td>
                                    <td style="padding: 10px 5px; text-align: right; font-size: 20px; font-weight: bold;">
                                        <t t-esc="'%g' % line.product_uom_qty"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Pie -->
                    <div style="text-align: center; margin-top: 30px; font-size: 12px; color: #999; border-top: 1px solid #ccc; padding-top: 10px;">
                        <t t-esc="o.env.company.name"/>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
