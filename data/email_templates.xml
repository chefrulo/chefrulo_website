<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="email_template_payment_request" model="mail.template">
        <field name="name">Payment Request</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="subject">Payment Request - {{ object.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333;">
    <p>Dear {{ object.partner_id.name }},</p>

    <p>Your order <strong>{{ object.name }}</strong> for
       <strong>£{{ '%.2f'|format(object.amount_total) }}</strong> is ready for payment.</p>

    <p style="margin: 24px 0;">
        <a href="{{ object.get_portal_url() }}"
           style="background-color: #875A7B; color: white; padding: 14px 28px;
                  text-decoration: none; border-radius: 4px; display: inline-block;
                  font-size: 16px; font-weight: bold;">
            Pay Now &mdash; £{{ '%.2f'|format(object.amount_total) }}
        </a>
    </p>

    <p>Do not hesitate to contact us if you have any questions.</p>

    <p>Kind regards,<br/>Chef Rulo &amp; Team</p>
</div>
        ]]></field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
